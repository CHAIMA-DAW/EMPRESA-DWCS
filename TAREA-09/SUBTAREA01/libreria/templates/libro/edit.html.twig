{% extends 'base.html.twig' %}

{% block title %}Editar libro{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="card shadow p-4">

        <h1 class="text-center mb-4">Editar libro</h1>

        <div class="mb-4">
            {{ include('libro/_form.html.twig', {
                'button_label': 'Actualizar'
            }) }}
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a href="{{ path('app_libro_index') }}" class="btn btn-secondary">
                ← Volver al listado
            </a>

            {{ include('libro/_delete_form.html.twig', {
                button_class: 'btn btn-danger'
            }) }}
        </div>

    </div>

</div>
{% endblock %}


