<form method="post" action="{{ path('app_libro_delete', {'id': libro.id}) }}"
      onsubmit="return confirm('¿Estás segura de que quieres eliminar este elemento?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ libro.id) }}">
    <button class="btn btn-primary">Eliminar</button>
</form>
